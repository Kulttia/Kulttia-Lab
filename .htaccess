# ============================================
# Kulttia Lab — .htaccess para frontend estático
# ============================================

# Forzar HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Quitar www (opcional pero recomendado)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# Clean URLs para artículos del blog
# /blog/mi-articulo -> articulo.html?slug=mi-articulo
RewriteRule ^blog/([a-z0-9_-]+)/?$ /articulo.html?slug=$1 [L,QSA]

# Página de inicio
DirectoryIndex index.html

# Páginas de error personalizadas
ErrorDocument 404 /index.html

# ============================================
# Cache del navegador (rendimiento)
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# ============================================
# Compresión GZIP (velocidad de carga)
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ============================================
# Seguridad básica
# ============================================
# Ocultar versión del servidor
ServerSignature Off

# Prevenir listado de directorios
Options -Indexes

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
