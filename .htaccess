# ============================================
# Kulttia Lab — .htaccess para frontend estático
# ============================================

RewriteEngine On

# ============================================
# Forzar HTTPS
# ============================================
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Quitar www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ============================================
# REDIRECTS 301 — Rutas del sitio anterior
# Esto elimina rastros en Google y evita 404s
# ============================================

# Páginas del sitio anterior → páginas equivalentes del nuevo sitio
RewriteRule ^herramientas/?$               https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^recursos/?$                   https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^articulos/?$                  https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^posts/?$                      https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^servicios/?$                  https://%{HTTP_HOST}/nosotros [R=301,L]
RewriteRule ^equipo/?$                     https://%{HTTP_HOST}/nosotros [R=301,L]
RewriteRule ^about/?$                      https://%{HTTP_HOST}/nosotros [R=301,L]
RewriteRule ^contactanos/?$                https://%{HTTP_HOST}/contacto [R=301,L]
RewriteRule ^contact/?$                    https://%{HTTP_HOST}/contacto [R=301,L]

# Páginas de WordPress que puedan quedar indexadas
RewriteRule ^wp-login\.php$               https://%{HTTP_HOST}/ [R=301,L]
RewriteRule ^wp-admin/?$                  https://%{HTTP_HOST}/ [R=301,L]
RewriteRule ^feed/?$                      https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^category/(.*)$              https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^tag/(.*)$                   https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^author/(.*)$               https://%{HTTP_HOST}/blog [R=301,L]
RewriteRule ^[0-9]{4}/[0-9]{2}/(.*)$    https://%{HTTP_HOST}/blog [R=301,L]

RewriteCond %{QUERY_STRING} ^s=(.*)$ [NC]
RewriteRule ^/?$ https://%{HTTP_HOST}/blog? [R=301,L]

RewriteCond %{QUERY_STRING} ^p=([0-9]+)$ [NC]
RewriteRule ^/?$ https://%{HTTP_HOST}/blog? [R=301,L]

# ============================================
# Clean URLs para artículos del blog
# /blog/mi-articulo → articulo.html?slug=mi-articulo
# ============================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/([a-zA-Z0-9_-]+)/?$  articulo.html?slug=$1 [L,QSA]

# ============================================
# Remover extensiones .html de las URLs
# ============================================

# Si alguien accede a /pagina.html -> redirige a /pagina (301) excluyendo query params
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L,QSA]

# Internamente sirve el .html cuando llega la URL limpia
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^/]+)/?$ $1.html [L,QSA]

# ============================================
# Página de inicio
# ============================================
DirectoryIndex index.html

# Errors: 404 muestra el home para que el JS maneje la ruta
ErrorDocument 404 /index.html

# ============================================
# Cache del navegador (rendimiento)
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                 "access plus 1 month"
    ExpiresByType application/javascript   "access plus 1 month"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType font/woff2               "access plus 1 year"
    # HTML corto para que los cambios se propaguen rápido
    ExpiresByType text/html                "access plus 2 hours"
</IfModule>

# ============================================
# Compresión GZIP (velocidad de carga)
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain application/json
</IfModule>

# ============================================
# Cabeceras de seguridad y rendimiento
# ============================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Preconnect hints para fuentes (mejora percibida de carga)
    Header add Link "<https://fonts.googleapis.com>; rel=preconnect"
    Header add Link "<https://fonts.gstatic.com>; rel=preconnect; crossorigin"
</IfModule>

# Seguridad: Ocultar versión y evitar listado de archivos
ServerSignature Off
Options -Indexes
